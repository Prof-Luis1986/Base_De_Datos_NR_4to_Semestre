rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /usuarios/{userId} {
      allow read, create, update: if request.auth != null
        && request.auth.uid == userId;
      allow delete: if false;

      match /practicas/{practicaId} {
        allow read, create, update: if request.auth != null
          && request.auth.uid == userId;
        allow delete: if false;
      }
    }
  }
}
